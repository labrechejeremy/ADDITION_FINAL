# Addition (ADD) - Professional Gitignore

# Build and Binary Folders
build/
bin/
lib/
out/
target/
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

# Data and Backups (Excluded for fresh repo)
data/
data_backup_*/
*.db
*.sqlite
*.log
*.tmp
*.bak

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*.sublime-*
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.env
pip-log.txt
setup.cfg

# Flutter / Dart
.dart_tool/
.packages
.pub-cache/
.pub/
client/addition_app/.flutter-plugins
client/addition_app/.flutter-plugins-dependencies
client/addition_app/build/

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# C++
*.o
*.obj
*.gch
*.pch
